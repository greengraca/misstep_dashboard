# ============================================
# MISSTEP — Environment Variables
# ============================================

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/misstep
MONGODB_DB_NAME=misstep

# NextAuth
AUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3001

# PIN Auth
# 5-digit numeric PIN for dashboard access (required)
APP_PIN=
